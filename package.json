{
  "name": "memory-server",
  "version": "1.0.0",
  "description": "A developer memory server hosted on Cloudflare with MCP support",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run",
    "db:migrate": "wrangler d1 migrations apply memory-db",
    "db:create-migration": "wrangler d1 migrations create memory-db",
    "ui:dev": "cd ui && npm run dev",
    "ui:build": "cd ui && npm run build",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "cf-typegen": "wrangler types"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "path-to-regexp": "^8.4.0",
    "picomatch": "^4.0.4",
    "ip-address": "^10.1.1",
    "rollup": "^4.59.0",
    "postcss": "^8.5.10",
    "vite": "^8.0.10",
    "qs": "^6.14.2",
    "ajv": "^8.18.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@modelcontextprotocol/ext-apps": "^1.7.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.3.10",
    "fetch-to-node": "^2.1.0",
    "fflate": "^0.8.2",
    "hono": "^4.12.17",
    "jose": "^6.2.3",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260506.1",
    "@types/node": "^20.19.39",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.88.0"
  },
  "keywords": [
    "cloudflare-workers",
    "memory",
    "mcp",
    "development"
  ],
  "author": "",
  "license": "MIT"
}
